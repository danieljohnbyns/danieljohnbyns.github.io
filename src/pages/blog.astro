---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog — Daniel John Baynosa" activePage="blog">
  <section class="py-20">
    <div class="container-main">
      <div class="mb-12">
        <h1 class="section-title">Blog</h1>
        <p class="text-text-secondary text-lg">
          Thoughts on system architecture, software engineering, and building things that scale.
        </p>
      </div>
      <div class="container-reading text-center py-16">
        <div class="w-16 h-16 rounded-2xl bg-surface border border-border flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <h2 class="text-2xl font-heading font-semibold text-text-primary mb-2">
          Coming Soon
        </h2>
        <p class="text-text-secondary">
          I'm working on my first posts about system architecture, AI agent engineering, and the lessons I've learned building production systems.
        </p>
      </div>
    </div>
  </section>
</Layout>
