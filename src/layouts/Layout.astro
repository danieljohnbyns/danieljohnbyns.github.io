---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  activePage?: 'home' | 'projects' | 'blog' | 'contact';
}

const {
  title = 'Daniel John Baynosa — System Architect',
  description = 'Building software systems that scale—from desktop applications to cloud-native platforms.',
  activePage,
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home', page: 'home' },
  { href: '/projects', label: 'Projects', page: 'projects' },
  { href: '/blog', label: 'Blog', page: 'blog' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Daniel John Baynosa" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://danieljohnbyns.github.io" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-bg text-text-primary antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-border">
      <div class="container-main flex items-center justify-between h-[72px]">
        <a href="/" class="text-lg font-heading font-bold text-primary">
          danieljohn<span class="text-accent">byns</span>
        </a>
        <div class="flex items-center gap-8">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`text-sm font-medium transition-colors relative pb-1 ${
                activePage === link.page
                  ? 'text-primary after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-primary'
                  : 'text-text-secondary hover:text-text-primary'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="/contact" class="btn-primary text-sm h-10 px-5">
            Get in Touch
          </a>
        </div>
      </div>
    </nav>

    <main class="pt-[72px]">
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="container-main py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-text-secondary">
          &copy; {new Date().getFullYear()} Daniel John Baynosa
        </p>
        <div class="flex items-center gap-6">
          <a href="https://github.com/danieljohnbyns" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/in/danieljohnbyns" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="mailto:danieljohnbyns@gmail.com" class="text-sm font-medium text-text-secondary hover:text-primary transition-colors">
            danieljohnbyns@gmail.com
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
