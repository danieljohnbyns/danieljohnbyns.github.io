---
<section class="container-main py-20 lg:py-28">
  <div class="grid lg:grid-cols-2 gap-12 items-center">
    <div class="animate-fade-in">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider mb-4">
        System Architect
      </p>
      <h1 class="text-[56px] leading-[1.1] font-bold text-text-primary mb-4">
        Daniel John<br />
        <span class="text-primary">Baynosa</span>
      </h1>
      <p class="text-lg text-text-secondary leading-relaxed mb-8 max-w-lg">
        I design and build scalable software systems — from desktop applications to cloud-native platforms.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/projects" class="btn-primary">
          View Projects
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contact" class="btn-secondary">
          Get in Touch
        </a>
      </div>
      <div class="flex items-center gap-4 mt-8 pt-8 border-t border-divider">
        <a href="https://github.com/danieljohnbyns" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/danieljohnbyns" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <span class="text-sm text-text-muted">danieljohnbyns@gmail.com</span>
      </div>
    </div>

    <div class="animate-slide-up">
      <div class="rounded-[24px] overflow-hidden border border-border shadow-[0_8px_24px_rgba(0,0,0,0.08)] bg-surface">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border bg-white">
          <span class="w-3 h-3 rounded-full bg-error/80" />
          <span class="w-3 h-3 rounded-full bg-warning/80" />
          <span class="w-3 h-3 rounded-full bg-success/80" />
          <span class="ml-2 text-xs font-mono text-text-muted">~/projects — bash</span>
        </div>
        <div class="p-6 bg-[#111827] text-sm font-mono leading-relaxed">
          <p><span class="text-success">danieljohn</span><span class="text-text-muted">@</span><span class="text-primary/70">portfolio</span><span class="text-text-muted">:</span><span class="text-primary/70">~</span><span class="text-text-muted">$ </span><span class="text-text-primary">ls projects/</span></p>
          <p class="text-text-secondary">cyra/ &nbsp; iOSAS/ &nbsp; RapCap/ &nbsp; tapang-sarap/</p>
          <p class="mt-1"><span class="text-success">danieljohn</span><span class="text-text-muted">@</span><span class="text-primary/70">portfolio</span><span class="text-text-muted">:</span><span class="text-primary/70">~</span><span class="text-text-muted">$ </span><span class="text-text-primary">cat /etc/profile</span></p>
          <p class="text-text-secondary">System Architect. Software Engineer. AI Agent Developer.</p>
          <p class="mt-1"><span class="text-success">danieljohn</span><span class="text-text-muted">@</span><span class="text-primary/70">portfolio</span><span class="text-text-muted">:</span><span class="text-primary/70">~</span><span class="text-text-muted">$ </span><span class="animate-pulse text-text-primary">_</span></p>
        </div>
      </div>
    </div>
  </div>
</section>
