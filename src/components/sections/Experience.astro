---
import Timeline from '../ui/Timeline.astro';
import experience from '../../data/experience.json';
---

<section class="py-20">
  <div class="container-main">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h2 class="section-title mb-0">Experience</h2>
        <p class="text-text-secondary text-lg mt-2">Where I've worked and what I've built.</p>
      </div>
      <a href="/experience" class="link-arrow hidden sm:flex">
        View all
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
    <div class="max-w-3xl">
      <Timeline items={experience} />
    </div>
  </div>
</section>
