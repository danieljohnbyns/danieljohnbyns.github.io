---
import skillsData from '../../data/skills.json';
---

<section class="py-20">
  <div class="container-main">
    <div class="text-center mb-12">
      <h2 class="section-title">Skills & Technologies</h2>
      <p class="text-text-secondary text-lg">Tools and technologies I work with regularly.</p>
    </div>
    <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
      {skillsData.categories.flatMap((cat) =>
        cat.skills.map((s) => <span class="tag text-sm px-4 py-2">{s}</span>)
      )}
    </div>
  </div>
</section>
