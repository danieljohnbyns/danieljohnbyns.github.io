---
interface Props {
  lines: string[];
  prompt?: string;
}
const { lines, prompt = '$' } = Astro.props;
---

<div class="rounded-xl border border-white/10 bg-black/40 backdrop-blur-sm overflow-hidden font-mono text-sm">
  <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-white/10 bg-black/20">
    <span class="w-2.5 h-2.5 rounded-full bg-red-500/80" />
    <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80" />
    <span class="w-2.5 h-2.5 rounded-full bg-green-500/80" />
  </div>
  <div class="p-4 space-y-1.5">
    {lines.map((line, i) => (
      <div class="flex items-start gap-2">
        {line.startsWith(prompt) ? (
          <>
            <span class="text-secondary shrink-0">{prompt}</span>
            <span class="text-text-primary">{line.slice(prompt.length).trim()}</span>
          </>
        ) : (
          <span class="text-text-secondary pl-4">{line}</span>
        )}
      </div>
    ))}
    <div class="flex items-center gap-2">
      <span class="text-secondary shrink-0">{prompt}</span>
      <span class="w-2 h-5 bg-text-primary/50 animate-pulse" />
    </div>
  </div>
</div>
