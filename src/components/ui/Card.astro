---
import Tag from './Tag.astro';

interface Link {
  github?: string;
  demo?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  tech: string[];
  links?: Link;
  featured?: boolean;
}

const { title, subtitle, description, tech, links, featured } = Astro.props;
---

<article class:list={['group relative p-6 rounded-xl border border-white/10 bg-surface/50 backdrop-blur-sm transition-all duration-300 hover:border-secondary/30 hover:glow', featured && 'lg:col-span-2']}>
  <div class="flex items-start justify-between mb-3">
    <div>
      <h3 class="text-lg font-heading font-semibold text-text-primary group-hover:text-secondary transition-colors">
        {title}
      </h3>
      {subtitle && (
        <p class="text-sm text-text-secondary mt-0.5">{subtitle}</p>
      )}
    </div>
    {featured && (
      <span class="text-xs font-mono font-medium text-secondary border border-secondary/30 rounded-full px-2 py-0.5">
        featured
      </span>
    )}
  </div>

  <p class="text-sm text-text-secondary leading-relaxed mb-4">
    {description}
  </p>

  <div class="flex flex-wrap gap-2 mb-4">
    {tech.map((t) => <Tag label={t} />)}
  </div>

  {links && (
    <div class="flex gap-3">
      {links.github && (
        <a
          href={links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-text-secondary hover:text-secondary transition-colors flex items-center gap-1"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      )}
      {links.demo && (
        <a
          href={links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-text-secondary hover:text-secondary transition-colors flex items-center gap-1"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Live Demo
        </a>
      )}
    </div>
  )}
</article>
