---
interface Experience {
  title: string;
  company: string;
  period: string;
  highlights: string[];
}

interface Props {
  items: Experience[];
}

const { items } = Astro.props;
---

<ol class="relative border-l border-white/10 ml-3 space-y-8">
  {items.map((item) => (
    <li class="relative pl-6">
      <div class="absolute left-0 top-1.5 -translate-x-1/2 w-3 h-3 rounded-full bg-secondary border-2 border-primary" />
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
        <h3 class="text-base font-heading font-semibold text-text-primary">
          {item.title}
        </h3>
        <span class="text-xs font-mono text-text-secondary">{item.period}</span>
      </div>
      <p class="text-sm font-medium text-secondary mb-2">{item.company}</p>
      <ul class="space-y-1">
        {item.highlights.map((h) => (
          <li class="text-sm text-text-secondary flex items-start gap-2">
            <span class="mt-1.5 w-1 h-1 rounded-full bg-text-secondary shrink-0" />
            {h}
          </li>
        ))}
      </ul>
    </li>
  ))}
</ol>
