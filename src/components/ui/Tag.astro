---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="inline-block px-3 py-1 text-xs font-mono font-medium rounded-full border border-white/10 bg-white/5 text-text-secondary hover:border-secondary/50 hover:text-secondary transition-colors duration-200">
  {label}
</span>
